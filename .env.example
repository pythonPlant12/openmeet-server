# Logging level (trace, debug, info, warn, error)
RUST_LOG=info

# Server bind address
BIND_ADDRESS=0.0.0.0:8081

# Database (PostgreSQL)
DATABASE_URL=postgres://openmeet:replace_with_a_long_random_database_password@postgres:5432/openmeet

# JWT Authentication
JWT_SECRET=replace_with_a_long_random_jwt_secret
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=7

# TLS Configuration
# Set to "true" for local development with mkcert certificates
# Leave empty or "false" for production (nginx handles SSL)
USE_TLS=false

# SSL Certificate paths (only used when USE_TLS=true)
SSL_CERT_PATH=../certs/localhost+3.pem
SSL_KEY_PATH=../certs/localhost+3-key.pem

# TURN Server credentials
TURN_URL=turn:turn.openmeets.eu:3478
TURN_USER=openmeet
TURN_PASSWORD=replace_with_a_long_random_turn_password

# STUN Server
STUN_URL=stun:stun.l.google.com:19302

# Public IP for NAT traversal (required for production behind NAT)
# This tells WebRTC to use this IP in ICE candidates instead of private IPs
PUBLIC_IP=<VPS_PUBLIC_IP>

# UDP Port range for WebRTC media (optional, recommended for production)
# Use a bounded range for easier firewall management
# Each peer connection uses ~2-4 UDP ports
UDP_PORT_MIN=50000
UDP_PORT_MAX=51000
